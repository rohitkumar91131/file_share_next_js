# -----------------------------------------------
# Sarvam AI – Text-to-Speech (https://sarvam.ai)
# Create an account, get a key, and paste it here.
# Without this key the "Hear it" voice button shows
# a friendly error; all other AI commentary features
# still work perfectly.
# -----------------------------------------------
SARVAM_API_KEY=your_sarvam_api_key_here

# Base URL used for share-link generation
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/fileshare
